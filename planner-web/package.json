{
  "name": "planner-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "api:generate": "orval",
    "api:generate:watch": "orval --watch",
    "dev": "VITE_DEBUG_LOGS=true vite",
    "start:dev": "pnpm run dev",
    "build": "tsc -b && vite build",
    "build:debug": "VITE_DEBUG_LOGS=true tsc -b && VITE_DEBUG_LOGS=true vite build",
    "lint": "eslint .",
    "format": "eslint . --fix && prettier --write \"**/*.{ts,tsx}\" \"!src/api/generated/**\" \"!src/routeTree.gen.ts\" && pnpm run format:project",
    "format:project": "prettier --write \"*.{json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "preview:debug": "VITE_DEBUG_LOGS=true vite preview",
    "test:e2e": "pnpm run test:e2e:install && playwright test",
    "test:e2e:ui": "pnpm run test:e2e:install && playwright test --ui",
    "test:e2e:headed": "pnpm run test:e2e:install && playwright test --headed",
    "test:e2e:debug": "pnpm run test:e2e:install && playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install chromium firefox",
    "test:e2e:install:deps:arch": "sudo pacman -S --needed nss nspr atk at-spi2-core cups libdrm gtk3 pango cairo alsa-lib libxcomposite libxdamage libxfixes libxrandr mesa libxcb libxkbcommon libx11 libxext libxrender libxshmfence libxtst expat dbus glib2 fontconfig freetype2 icu libxml2 && (sudo pacman -S --needed libxml2-legacy || true) && (command -v yay >/dev/null 2>&1 && yay -S --needed icu74 || command -v paru >/dev/null 2>&1 && paru -S --needed icu74 || echo 'AUR helper not found. Install icu74 from AUR manually if Playwright still reports missing libicu74.')",
    "test:e2e:install:deps:ci": "playwright install --with-deps chromium firefox"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.79.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@faker-js/faker": "^10.4.0",
    "@msw/playwright": "^0.6.7",
    "@playwright/test": "^1.61.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "orval": "^8.16.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vite": "^8",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
