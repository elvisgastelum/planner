{
  "name": "planner-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "api:generate": "orval",
    "api:generate:watch": "orval --watch",
    "dev": "vite",
    "dev:debug": "VITE_DEBUG_LOGS=true vite",
    "build": "tsc -b && vite build",
    "build:debug": "VITE_DEBUG_LOGS=true tsc -b && VITE_DEBUG_LOGS=true vite build",
    "lint": "eslint .",
    "format": "eslint . --fix && prettier --write \"**/*.{ts,tsx}\" \"!src/api/generated/**\" \"!src/routeTree.gen.ts\"",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "preview:debug": "VITE_DEBUG_LOGS=true vite preview"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@faker-js/faker": "^10.4.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17",
    "msw": "^2.14.6",
    "orval": "^8.16.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vite": "^8"
  }
}
